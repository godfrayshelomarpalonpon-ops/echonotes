{
  "version": 2,
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/favicon.ico",
      "dest": "echonotes/static/images/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "index.py"
    }
  ]
}
